{
  "version": 1,
  "project": "redemption",
  "publicEntry": "gateway",
  "services": {
    "gateway": {
      "type": "docker",
      "context": "./gateway",
      "dockerfile": "Dockerfile",
      "port": 8080,
      "public": true,
      "dependsOn": [
        "web",
        "api"
      ],
      "environment": [
        "PORT",
        "API_UPSTREAM",
        "WEB_UPSTREAM"
      ]
    },
    "web": {
      "type": "docker",
      "context": ".",
      "dockerfile": "Dockerfile",
      "port": 3000,
      "public": false,
      "dependsOn": [
        "api"
      ],
      "environment": [
        "NODE_ENV",
        "PORT",
        "NEXT_PUBLIC_BASE_URL",
        "SESSION_SECRET",
        "ADMIN_USERNAMES"
      ]
    },
    "api": {
      "type": "docker",
      "context": "./backend",
      "dockerfile": "Dockerfile",
      "port": 8080,
      "public": false,
      "dependsOn": [
        "postgres",
        "redis"
      ],
      "environment": [
        "APP_MODE",
        "PORT",
        "DATABASE_URL",
        "REDIS_URL",
        "SESSION_SECRET",
        "ADMIN_USERNAMES",
        "INTERNAL_API_SECRET",
        "NEW_API_URL",
        "NEW_API_ADMIN_ACCESS_TOKEN",
        "NEW_API_ADMIN_USER_ID",
        "R2_PUBLIC_URL",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET_FEEDBACK_IMAGES",
        "S3_BUCKET_CARD_IMAGES"
      ]
    },
    "worker": {
      "type": "docker",
      "context": "./backend",
      "dockerfile": "Dockerfile",
      "entrypoint": "/app/worker",
      "public": false,
      "dependsOn": [
        "postgres",
        "redis"
      ],
      "environment": [
        "APP_MODE",
        "DATABASE_URL",
        "REDIS_URL",
        "SESSION_SECRET",
        "ADMIN_USERNAMES",
        "INTERNAL_API_SECRET",
        "RAFFLE_DELIVERY_CRON_SECRET",
        "CRON_SECRET"
      ]
    },
    "postgres": {
      "type": "managed-postgres",
      "public": false,
      "provides": [
        "DATABASE_URL"
      ]
    },
    "redis": {
      "type": "managed-redis",
      "public": false,
      "provides": [
        "REDIS_URL"
      ]
    }
  },
  "postDeployChecks": [
    "GET /healthz",
    "GET /readyz",
    "node scripts/smoke-zeabur-runtime.mjs",
    "node scripts/preflight-zeabur-go-api.mjs"
  ],
  "forbiddenPublicServices": [
    "web",
    "api",
    "worker",
    "postgres",
    "redis"
  ]
}
