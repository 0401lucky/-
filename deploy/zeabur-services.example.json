{
  "version": 1,
  "project": "redemption",
  "publicEntry": "app",
  "services": {
    "app": {
      "type": "docker",
      "context": ".",
      "dockerfile": "Dockerfile",
      "port": 8080,
      "public": true,
      "dependsOn": [
        "postgres",
        "redis"
      ],
      "environment": [
        "WEB_PORT",
        "API_PORT",
        "GATEWAY_PORT",
        "NEXT_PUBLIC_BASE_URL",
        "SESSION_SECRET",
        "ADMIN_USERNAMES",
        "APP_MODE",
        "DATABASE_URL",
        "REDIS_URL",
        "INTERNAL_API_SECRET",
        "RAFFLE_DELIVERY_CRON_SECRET",
        "CRON_SECRET",
        "NEW_API_URL",
        "NEW_API_ADMIN_ACCESS_TOKEN",
        "NEW_API_ADMIN_USER_ID",
        "NEW_API_ADMIN_USERNAME",
        "NEW_API_ADMIN_PASSWORD",
        "R2_PUBLIC_URL",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET_FEEDBACK_IMAGES",
        "S3_BUCKET_CARD_IMAGES",
        "FEEDBACK_MEDIA_DIR",
        "FEEDBACK_MEDIA_PUBLIC_URL"
      ]
    },
    "postgres": {
      "type": "managed-postgres",
      "public": false,
      "provides": [
        "DATABASE_URL"
      ]
    },
    "redis": {
      "type": "managed-redis",
      "public": false,
      "provides": [
        "REDIS_URL"
      ]
    }
  },
  "postDeployChecks": [
    "GET /healthz",
    "GET /readyz",
    "node scripts/smoke-zeabur-runtime.mjs",
    "node scripts/preflight-zeabur-go-api.mjs"
  ],
  "forbiddenPublicServices": [
    "postgres",
    "redis"
  ]
}
