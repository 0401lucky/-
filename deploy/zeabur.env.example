# Web service
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_BASE_URL=https://your-domain.example.com

# Gateway service
# Override these if Zeabur internal service hostnames differ from the local Docker names.
API_UPSTREAM=api:8080
WEB_UPSTREAM=web:3000

# Web / Go API shared auth
# These two values must be identical in the Web and Go API services.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_USERNAMES=admin,lucky

# Go API / Worker
APP_MODE=api
DATABASE_URL=${POSTGRES_CONNECTION_STRING}
REDIS_URL=${REDIS_CONNECTION_STRING}
INTERNAL_API_SECRET=replace-with-a-random-internal-secret

# External new-api integration
NEW_API_URL=https://your-new-api.example.com
NEW_API_ADMIN_ACCESS_TOKEN=replace-with-new-api-admin-token
NEW_API_ADMIN_USER_ID=replace-with-new-api-admin-user-id

# Cron / worker auth
RAFFLE_DELIVERY_CRON_SECRET=replace-with-a-random-secret
CRON_SECRET=replace-with-a-random-secret

# R2 / S3 compatible object storage
R2_PUBLIC_URL=https://r2.example.com
S3_ENDPOINT=https://account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=replace-with-r2-access-key
S3_SECRET_ACCESS_KEY=replace-with-r2-secret-key
S3_BUCKET_FEEDBACK_IMAGES=feedback-images
S3_BUCKET_CARD_IMAGES=card-images

# Feedback media local fallback for Go API.
# On Zeabur, mount a persistent volume to this path if S3/R2 upload is not enabled yet.
FEEDBACK_MEDIA_DIR=/data/feedback-media
FEEDBACK_MEDIA_PUBLIC_URL=
