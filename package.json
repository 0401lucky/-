{
  "name": "redemption-code-distributor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:feedback-images": "node scripts/migrate-feedback-images-to-blob.mjs",
    "migrate:feedback-images:execute": "node scripts/migrate-feedback-images-to-blob.mjs --execute",
    "opennext:patch": "node scripts/patch-opennext-windows.mjs",
    "preview": "npm run opennext:patch && node scripts/build-cloudflare.mjs && opennextjs-cloudflare preview",
    "deploy": "npm run opennext:patch && node scripts/build-cloudflare.mjs && opennextjs-cloudflare deploy",
    "upload": "npm run opennext:patch && node scripts/build-cloudflare.mjs && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vercel/kv": "^3.0.0",
    "autoprefixer": "^10.4.23",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "matter-js": "^0.20.0",
    "nanoid": "^3.3.11",
    "next": "^16.1.3",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "seedrandom": "^3.0.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/matter-js": "^0.20.2",
    "@types/seedrandom": "^3.0.8",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.4",
    "jsdom": "^27.4.0",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
